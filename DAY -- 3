// problem 2
// print even number from 0 to 10

#include <iostream>
using namespace std;
int main(){
    for(int i = 0; i<=10; i=i+2){
        cout << i << "";
    }
}


// problem 3
// print 1 to 10 using while loop

#include <iostream>
using namespace std;

int main(){
    int i = 1;
    while(i<=10){
        cout << i << "";
        i++;
    }
}


